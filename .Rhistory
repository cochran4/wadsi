# Load required library
library(ggplot2)
library(tidyr)
library(dplyr)
# Create the data frame
df <- data.frame(
honeme_group = c(
"Vowels_Level1_Level2",
"Vowels_Level4_Level5",
"Vowels_Level3",
"Consonants_Level3",
"Consonants_Level4",
"Consonants_Level5",
"Consonants_Level6"
),
model0 = c(2372.401, 2404.282, 2137.326, 1588.812, 2206.72, 1997.365, 3392.083),
model1 = c(2353.463, 2400.335, 2133.97, 1585.823, 2199.826, 1988.928, 3394.443),
model2 = c(2156.426, 2109.844, 1847.267, 1454.607, 1091.63, 1705.229, 3015.966),
model5 = c(2390.861, 2408.223, 2143.506, 1593.913, 2209.201, 2002.034, 3395.633),
model4 = c(2390.813, 2408.925, 2143.099, 1593.435, 2209.313, 2003.448, 3395.839),
model6 = c(2389.415, 2408.521, 2142.881, 1592.723, 2210.509, 2003.823, 3394.411),
model3 = c(2403.365, 2403.969, 2137.805, 1587.373, 2205.397, 1998.001, 3419.95),
model7 = c(2390.616, 2405.102, 2133.954, 1585.398, 2199.312, 1989.43, 3419.083)
)
# Reshape to long format
df_long <- df %>%
pivot_longer(cols = -honeme_group, names_to = "model", values_to = "value")
# Plot
ggplot(df_long, aes(x = honeme_group, y = value, color = model, group = model)) +
geom_line() +
geom_point() +
labs(title = "Model Values by Honeme Group", x = "Honeme Group", y = "Value") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Filter out model2
df_long_filtered <- df_long %>% filter(model != "model2")
# Plot excluding model2
ggplot(df_long_filtered, aes(x = honeme_group, y = value, color = model, group = model)) +
geom_line() +
geom_point() +
labs(title = "Model Values by Honeme Group (Excluding model2)", x = "Honeme Group", y = "Value") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
library(dplyr)
library(tidyr)
library(ggplot2)
# Create the original data frame (same as before)
df <- data.frame(
honeme_group = c(
"Vowels_Level1_Level2",
"Vowels_Level4_Level5",
"Vowels_Level3",
"Consonants_Level3",
"Consonants_Level4",
"Consonants_Level5",
"Consonants_Level6"
),
model0 = c(2372.401, 2404.282, 2137.326, 1588.812, 2206.72, 1997.365, 3392.083),
model1 = c(2353.463, 2400.335, 2133.97, 1585.823, 2199.826, 1988.928, 3394.443),
model2 = c(2156.426, 2109.844, 1847.267, 1454.607, 1091.63, 1705.229, 3015.966),
model5 = c(2390.861, 2408.223, 2143.506, 1593.913, 2209.201, 2002.034, 3395.633),
model4 = c(2390.813, 2408.925, 2143.099, 1593.435, 2209.313, 2003.448, 3395.839),
model6 = c(2389.415, 2408.521, 2142.881, 1592.723, 2210.509, 2003.823, 3394.411),
model3 = c(2403.365, 2403.969, 2137.805, 1587.373, 2205.397, 1998.001, 3419.95),
model7 = c(2390.616, 2405.102, 2133.954, 1585.398, 2199.312, 1989.43, 3419.083)
)
# Pivot to long format
df_long <- df %>%
pivot_longer(cols = -honeme_group, names_to = "model", values_to = "value")
# Extract model0 values
model0_values <- df_long %>%
filter(model == "model0") %>%
select(honeme_group, model0_value = value)
# Merge and compute difference from model0
df_relative <- df_long %>%
filter(model != "model2") %>%  # Exclude model2
left_join(model0_values, by = "honeme_group") %>%
mutate(delta = value - model0_value)
# Plot
ggplot(df_relative, aes(x = honeme_group, y = delta, color = model, group = model)) +
geom_line() +
geom_point() +
labs(title = "Model Differences Relative to model0", y = "Value - model0", x = "Honeme Group") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
View(df_long_filtered)
library(ggplot2)
library(dplyr)
set.seed(1)
threshold <- 0.5
x <- seq(0, 1, length.out = 200)
# potential outcomes
y_no  <- 0.15 + 0.5*x
y_yes <- y_no - 0.12   # referral reduces risk
# observed outcome follows assignment rule
y_obs <- ifelse(x < threshold, y_no, y_yes)
df <- data.frame(
x = rep(x, 3),
y = c(y_obs, y_yes, y_no),
type = rep(c("Observed", "Referral", "No referral"), each = length(x))
)
ggplot(df, aes(x, y, color = type, linetype = type)) +
geom_line(size = 1.4) +
geom_vline(xintercept = threshold,
linetype = "dashed",
size = 1.2) +
scale_color_manual(values = c(
"Observed" = "black",
"Referral" = "#2ca25f",
"No referral" = "#3182bd"
)) +
scale_linetype_manual(values = c(
"Observed" = "solid",
"Referral" = "dashed",
"No referral" = "dashed"
)) +
scale_x_continuous(
labels = scales::percent_format(accuracy = 1),
limits = c(0,1)
) +
labs(
x = "Predicted fall risk",
y = "Actual fall risk"
) +
theme_classic(base_size = 18) +
theme(
legend.title = element_blank()
)
library(ggplot2)
library(dplyr)
library(showtext)
install.packages("showtext")
library(ggplot2)
library(dplyr)
library(showtext)
# optional: use Roboto to match your slides
font_add_google("Roboto", "roboto")
showtext_auto()
threshold <- 0.5
x <- seq(0, 1, length.out = 400)
# potential outcomes
y_no  <- 0.18 + 0.45*x
y_yes <- y_no - 0.12
# observed outcomes follow assignment rule
y_obs <- ifelse(x < threshold, y_no, y_yes)
df <- data.frame(
x = rep(x, 3),
y = c(y_obs, y_yes, y_no),
type = factor(
rep(c("Observed outcomes",
"Potential outcomes: referral",
"Potential outcomes: no referral"),
each = length(x)),
levels = c("Observed outcomes",
"Potential outcomes: referral",
"Potential outcomes: no referral")
)
)
ggplot(df, aes(x, y, color = type, linetype = type)) +
geom_line(linewidth = 2) +
geom_vline(
xintercept = threshold,
linetype = "dashed",
linewidth = 1.2,
color = "black"
) +
scale_color_manual(values = c(
"Observed outcomes" = "#222222",
"Potential outcomes: referral" = "#2ca25f",
"Potential outcomes: no referral" = "#3182bd"
)) +
scale_linetype_manual(values = c(
"Observed outcomes" = "solid",
"Potential outcomes: referral" = "dashed",
"Potential outcomes: no referral" = "dashed"
)) +
scale_x_continuous(
labels = scales::percent_format(accuracy = 1),
breaks = c(0, .25, .5, .75, 1),
limits = c(0,1)
) +
labs(
x = "Predicted fall risk",
y = "Actual fall risk"
) +
theme_void(base_family = "roboto") +
theme(
axis.line = element_line(linewidth = 1.2, color = "black"),
axis.text = element_text(size = 16),
axis.title = element_text(size = 20, margin = margin(10,10,10,10)),
legend.position = "top",
legend.text = element_text(size = 18),
plot.margin = margin(20,40,20,40)
)
