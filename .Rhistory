# Load required library
library(ggplot2)
library(tidyr)
library(dplyr)
# Create the data frame
df <- data.frame(
honeme_group = c(
"Vowels_Level1_Level2",
"Vowels_Level4_Level5",
"Vowels_Level3",
"Consonants_Level3",
"Consonants_Level4",
"Consonants_Level5",
"Consonants_Level6"
),
model0 = c(2372.401, 2404.282, 2137.326, 1588.812, 2206.72, 1997.365, 3392.083),
model1 = c(2353.463, 2400.335, 2133.97, 1585.823, 2199.826, 1988.928, 3394.443),
model2 = c(2156.426, 2109.844, 1847.267, 1454.607, 1091.63, 1705.229, 3015.966),
model5 = c(2390.861, 2408.223, 2143.506, 1593.913, 2209.201, 2002.034, 3395.633),
model4 = c(2390.813, 2408.925, 2143.099, 1593.435, 2209.313, 2003.448, 3395.839),
model6 = c(2389.415, 2408.521, 2142.881, 1592.723, 2210.509, 2003.823, 3394.411),
model3 = c(2403.365, 2403.969, 2137.805, 1587.373, 2205.397, 1998.001, 3419.95),
model7 = c(2390.616, 2405.102, 2133.954, 1585.398, 2199.312, 1989.43, 3419.083)
)
# Reshape to long format
df_long <- df %>%
pivot_longer(cols = -honeme_group, names_to = "model", values_to = "value")
# Plot
ggplot(df_long, aes(x = honeme_group, y = value, color = model, group = model)) +
geom_line() +
geom_point() +
labs(title = "Model Values by Honeme Group", x = "Honeme Group", y = "Value") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Filter out model2
df_long_filtered <- df_long %>% filter(model != "model2")
# Plot excluding model2
ggplot(df_long_filtered, aes(x = honeme_group, y = value, color = model, group = model)) +
geom_line() +
geom_point() +
labs(title = "Model Values by Honeme Group (Excluding model2)", x = "Honeme Group", y = "Value") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
library(dplyr)
library(tidyr)
library(ggplot2)
# Create the original data frame (same as before)
df <- data.frame(
honeme_group = c(
"Vowels_Level1_Level2",
"Vowels_Level4_Level5",
"Vowels_Level3",
"Consonants_Level3",
"Consonants_Level4",
"Consonants_Level5",
"Consonants_Level6"
),
model0 = c(2372.401, 2404.282, 2137.326, 1588.812, 2206.72, 1997.365, 3392.083),
model1 = c(2353.463, 2400.335, 2133.97, 1585.823, 2199.826, 1988.928, 3394.443),
model2 = c(2156.426, 2109.844, 1847.267, 1454.607, 1091.63, 1705.229, 3015.966),
model5 = c(2390.861, 2408.223, 2143.506, 1593.913, 2209.201, 2002.034, 3395.633),
model4 = c(2390.813, 2408.925, 2143.099, 1593.435, 2209.313, 2003.448, 3395.839),
model6 = c(2389.415, 2408.521, 2142.881, 1592.723, 2210.509, 2003.823, 3394.411),
model3 = c(2403.365, 2403.969, 2137.805, 1587.373, 2205.397, 1998.001, 3419.95),
model7 = c(2390.616, 2405.102, 2133.954, 1585.398, 2199.312, 1989.43, 3419.083)
)
# Pivot to long format
df_long <- df %>%
pivot_longer(cols = -honeme_group, names_to = "model", values_to = "value")
# Extract model0 values
model0_values <- df_long %>%
filter(model == "model0") %>%
select(honeme_group, model0_value = value)
# Merge and compute difference from model0
df_relative <- df_long %>%
filter(model != "model2") %>%  # Exclude model2
left_join(model0_values, by = "honeme_group") %>%
mutate(delta = value - model0_value)
# Plot
ggplot(df_relative, aes(x = honeme_group, y = delta, color = model, group = model)) +
geom_line() +
geom_point() +
labs(title = "Model Differences Relative to model0", y = "Value - model0", x = "Honeme Group") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
View(df_long_filtered)
